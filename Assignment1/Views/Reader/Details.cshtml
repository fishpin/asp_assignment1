@model Reader

@{
    ViewData["Title"] = "Reader Details";
}

<h1>Reader Details</h1>

<dl>
    <dt>Name</dt>
    <dd>@Model.FullName</dd>
    <dt>Email</dt>
    <dd>@Model.Email</dd>
    <dt>Phone Number</dt>
    <dd>@Model.PhoneNumber</dd>
    <dt>Address</dt>
    <dd>@Model.Address</dd>
    <dt>Member Since</dt>
    <dd>@Model.MemberSince</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
<a asp-action="Index">Back to List</a>