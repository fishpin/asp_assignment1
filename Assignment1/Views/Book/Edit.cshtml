@model Book

@{
    ViewData["Title"] = "Edit Book";
}

<h1>Edit Book</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div>
        <label asp-for="Title"></label>
        <input asp-for="Title" />
        <span asp-validation-for="Title"></span>
    </div>
    <div>
        <label asp-for="Author"></label>
        <input asp-for="Author" />
        <span asp-validation-for="Author"></span>
    </div>
    <div>
        <label asp-for="ISBN"></label>
        <input asp-for="ISBN" />
        <span asp-validation-for="ISBN"></span>
    </div>
    <div>
        <label asp-for="Genre"></label>
        <input asp-for="Genre" />
        <span asp-validation-for="Genre"></span>
    </div>
    <div>
        <label asp-for="YearPublished"></label>
        <input asp-for="YearPublished" />
        <span asp-validation-for="YearPublished"></span>
    </div>
    <div>
        <label asp-for="IsAvailable"></label>
        <input asp-for="IsAvailable" />
    </div>
    <button type="submit">Save Changes</button>
</form>

<a asp-action="Index">Back to List</a>