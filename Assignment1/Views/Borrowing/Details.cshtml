@model Borrowing

@{
    ViewData["Title"] = "Borrowing Details";
}

<h1>Borrowing Details</h1>

<dl>
    <dt>Book ID</dt>
    <dd>@Model.BookId</dd>
    <dt>Reader ID</dt>
    <dd>@Model.ReaderId</dd>
    <dt>Borrow Date</dt>
    <dd>@Model.BorrowDate</dd>
    <dt>Due Date</dt>
    <dd>@Model.DueDate</dd>
    <dt>Return Date</dt>
    <dd>@Model.ReturnDate</dd>
    <dt>Late Fee</dt>
    <dd>@Model.OverdueFee</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
<a asp-action="Index">Back to List</a>