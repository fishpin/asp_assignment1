@model Borrowing

@{
    ViewData["Title"] = "Delete Borrowing";
}

<h1>Delete Borrowing</h1>

<p>Are you sure you want to delete this borrowing?</p>

<dl>
    <dt>Book ID</dt>
    <dd>@Model.BookId</dd>
    <dt>Reader ID</dt>
    <dd>@Model.ReaderId</dd>
    <dt>Borrow Date</dt>
    <dd>@Model.BorrowDate</dd>
    <dt>Due Date</dt>
    <dd>@Model.DueDate</dd>
    <dt>Return Date</dt>
    <dd>@Model.ReturnDate</dd>
    <dt>Late Fee</dt>
    <dd>@Model.OverdueFee</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit">Yes, Delete</button>
</form>

<a asp-action="Index">Back to List</a>