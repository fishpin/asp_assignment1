<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title - Library Management System</title>
</head>
<body>
    <nav>
        <a href="/">Home</a> |
        <a asp-controller="Book" asp-action="Index">Books</a> |
        <a asp-controller="Reader" asp-action="Index">Readers</a> |
        <a asp-controller="Borrowing" asp-action="Index">Borrowings</a> |
        <a asp-controller="Account" asp-action="Login">Login</a> |
