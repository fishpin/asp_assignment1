@model Book

@{
    ViewData["Title"] = "Book Details";
}

<h1>Book Details</h1>

<dl>
    <dt>Title</dt>
    <dd>@Model.Title</dd>
    <dt>Author</dt>
    <dd>@Model.Author</dd>
    <dt>ISBN</dt>
    <dd>@Model.ISBN</dd>
    <dt>Genre</dt>
    <dd>@Model.Genre</dd>
    <dt>Year Published</dt>
    <dd>@Model.YearPublished</dd>
    <dt>Available</dt>
    <dd>@Model.IsAvailable</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
<a asp-action="Index">Back to List</a>