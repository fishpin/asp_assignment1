@model Reader

@{
    ViewData["Title"] = "Delete Reader";
}

<h1>Delete Reader</h1>

<p>Are you sure you want to delete this reader?</p>

<dl>
    <dt>Name</dt>
    <dd>@Model.FullName</dd>
    <dt>Email</dt>
    <dd>@Model.Email</dd>
    <dt>Phone Number</dt>
    <dd>@Model.PhoneNumber</dd>
    <dt>Address</dt>
    <dd>@Model.Address</dd>
    <dt>Member Since</dt>
    <dd>@Model.MemberSince</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit">Yes, Delete</button>
</form>

<a asp-action="Index">Back to List</a>