@model List<Reader>

@{
    ViewData["Title"] = "Search Readers";
}

<h1 class="mb-3">Search Results</h1>

<form asp-action="Search" method="get" class="mb-3 d-flex gap-2">
    <input type="text" name="query" placeholder="Search by name, email or address" class="form-control" />
    <button type="submit" class="btn btn-secondary">Search</button>
</form>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Phone Number</th>
            <th>Address</th>
            <th>Member Since</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reader in Model)
        {
            <tr>
                <td>@reader.FullName</td>
                <td>@reader.Email</td>
                <td>@reader.PhoneNumber</td>
                <td>@reader.Address</td>
                <td>@reader.MemberSince</td>
                <td>
                    <a asp-action="Details" asp-route-id="@reader.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@reader.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@reader.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Back to List</a>